rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      // Users can read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Partners can read user details if they have an assigned request for that user
      allow read: if request.auth != null && 
        exists(/databases/$(database)/documents/wasteRequests/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/wasteRequests/$(request.auth.uid)).data.userId == userId;
    }
    
    // Waste requests collection
    match /wasteRequests/{requestId} {
      // Users can read their own requests
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      
      // Users can create requests
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Partners can read requests assigned to them
      allow read: if request.auth != null && resource.data.partnerId == request.auth.uid;
      
      // Partners can update requests assigned to them (status, ecoPoints, etc.)
      allow update: if request.auth != null && resource.data.partnerId == request.auth.uid;
      
      // Users can update their own requests (before partner assignment)
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Partners collection (if you have one)
    match /partners/{partnerId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == partnerId;
    }
    
    // Rewards collection (catalog of available rewards)
    match /rewards/{rewardId} {
      // All authenticated users can read active rewards
      allow read: if request.auth != null;
      // Only admins can write (manage via Firebase Console)
      allow write: if false;
    }
    
    // Reward transactions collection
    match /rewardTransactions/{transactionId} {
      // Users can read their own transactions
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // System creates transactions (via Cloud Functions or backend)
      allow create: if request.auth != null;
    }
    
    // Scheduled pickups collection
    match /scheduledPickups/{scheduleId} {
      // Users can read their own schedules
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Partners can read and create schedules for their assigned requests
      allow read, create: if request.auth != null && resource.data.partnerId == request.auth.uid;
      // Partners can update schedules they created
      allow update: if request.auth != null && resource.data.partnerId == request.auth.uid;
    }
    
    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
